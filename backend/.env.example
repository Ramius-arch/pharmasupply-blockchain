# Environment variables for the backend
# Copy this file to .env and fill in real values. Never commit .env to source control.

NODE_ENV=development

# MongoDB Connection URI
MONGODB_URI=mongodb://localhost:27017/pharmasupply

# JSON Web Token Secret — generate a strong random string (e.g., openssl rand -base64 32)
JWT_SECRET=change-me-to-a-strong-random-secret

# Log Level (e.g., 'info', 'debug', 'warn', 'error')
LOG_LEVEL=info

# Port for the backend server
PORT=3000

# CORS allowed origin(s) for production
# CORS_ORIGIN=http://localhost:5173

# Blockchain RPC URL
HARDHAT_RPC_URL=http://127.0.0.1:8545

# Private key for the backend signing wallet (dev only — use a KMS/HSM in production)
# NEVER use a real/mainnet key here.
DEV_PRIVATE_KEY=

# Optional: override contract address and ABI from environment instead of contract-address.json
# BLOCKCHAIN_CONTRACT_ADDRESS=0x...
# BLOCKCHAIN_CONTRACT_ABI=[...]
